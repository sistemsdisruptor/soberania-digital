# ============================================================
# SOBERANÍA DIGITAL — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
# 1. Copiá este archivo como .env
# 2. Completá los valores reales
# 3. NUNCA subas .env a GitHub — está en .gitignore
# 4. Cada entorno (local, producción) tiene su propio .env
# ============================================================

# -- ENTORNO --------------------------------------------------
NODE_ENV=development
# Opciones: development | production | test

# -- SERVIDOR -------------------------------------------------
PORT=3000
HOST=localhost

# -- SEGURIDAD ------------------------------------------------
# Clave de firma interna (generala con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SIGNING_KEY=REEMPLAZAR_CON_CLAVE_GENERADA_LOCALMENTE

# Clave de cifrado para datos sensibles en tránsito interno
ENCRYPTION_KEY=REEMPLAZAR_CON_CLAVE_GENERADA_LOCALMENTE

# -- LOGGING --------------------------------------------------
# Nivel de detalle de logs: error | warn | info | debug
LOG_LEVEL=info

# Directorio donde se guardan los logs forenses
LOG_DIR=./logs

# -- BLOCKCHAIN (se completa en Fase 2) -----------------------
POLYGON_RPC_URL=
BLOCKCHAIN_WALLET_ADDRESS=
BLOCKCHAIN_PRIVATE_KEY=

# -- FUENTES DE DATOS DEL ESTADO ------------------------------
# URLs base de los portales gubernamentales
DATOS_GUB_UY_API=https://catalogodatos.gub.uy/api/3
COMPRAS_GUB_UY_API=https://www.gub.uy/agencia-compras-contrataciones-estado
MEF_API=https://www.mef.gub.uy

# -- ALERTAS (se completa cuando se configure) ----------------
ALERT_EMAIL=
ALERT_WEBHOOK_URL=
